# Database URL (SQLite for development, MySQL/PostgreSQL for production)
# SQLite is easiest for local development - the database file is created automatically
DATABASE_URL="file:./db/custom.db"

# For production with MySQL:
# DATABASE_URL="mysql://user:password@localhost:3306/bbms_ghana"

# For production with PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/bbms_ghana?schema=public"

# Python binary path (optional - only needed for PDF/DOCX report export)
# Leave unset to use system default (python3), or set to your Python path
# PDF/DOCX export also requires: pip install reportlab python-docx
# PYTHON_BIN="/usr/bin/python3"
